# Copy to `.env` and fill in. `.env` is gitignored — never commit real credentials.
#
# Get a Kaggle API token from: https://www.kaggle.com/settings/account
#   Account → API → "Create New Token" → downloads kaggle.json
#
# You can either:
#   (a) set the two env vars below (e.g. via python-dotenv), OR
#   (b) place the downloaded kaggle.json at:
#         Windows:  %USERPROFILE%\.kaggle\kaggle.json
#         macOS/Linux: ~/.kaggle/kaggle.json   (chmod 600)

KAGGLE_USERNAME=
KAGGLE_KEY=
